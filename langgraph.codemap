        },
        {
          "id": "6c",
          "path": "/home/resu/Documents/dev/alex-c.code-canvas-app-0.14.8/node_modules/@ast-grep/napi/types/config.d.ts",
          "lineNumber": 32,
          "lineContent": "  matcher: NapiConfig\u003cM\u003e",
          "title": "Конфигурация поиска",
