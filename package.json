{
  "name": "infinity-canvas",
  "private": true,
  "version": "0.0.0",
  "description": "Infinity Canvas — Electron Split App: LEFT semantic canvas | RIGHT detail pane",
  "scripts": {
    "dev": "pnpm --filter @infinity-canvas/desktop dev",
    "build": "pnpm --filter @infinity-canvas/desktop build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:live-llm": "tsx packages/semantic/scripts/live-haiku-smoke.ts",
    "dist:linux": "pnpm --filter @infinity-canvas/desktop dist:linux",
    "dist:mac": "pnpm --filter @infinity-canvas/desktop dist:mac",
    "dist:win": "pnpm --filter @infinity-canvas/desktop dist:win",
    "pack": "pnpm --filter @infinity-canvas/desktop pack",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.10.0",
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
