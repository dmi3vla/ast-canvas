# LLM provider configuration
# Copy to monorepo root `.env` (or `.env.local`) — loaded by Electron main at startup.
#   cp .env.example .env
#
# Local gateway (OpenAI-compatible):
INFINITY_LLM_PROVIDER=openai-compatible
INFINITY_LLM_BASE_URL=http://localhost:20128/v1
# Any non-empty key works for most local proxies; required so app does not fall back to Mock
INFINITY_LLM_API_KEY=local
INFINITY_LLM_MODEL=kr/claude-haiku-4.5
# Privacy: send code samples to LLM during enrich/map? (0=safer, 1=full context)
INFINITY_LLM_SEND_SAMPLES=0

# Prompt debug log (default on): full chat IN + OUT under
#   <workspace>/.infinity-canvas/logs/prompts/
#   prompts.jsonl, <id>-in.json, <id>-out.txt
# Set to 0 to disable
INFINITY_LLM_LOG_PROMPTS=1

# --- curl smoke (run against the same base URL) ---
# curl -sS http://localhost:20128/v1/models | head
# curl -sS http://localhost:20128/v1/chat/completions \
#   -H 'Content-Type: application/json' \
#   -H 'Authorization: Bearer local' \
#   -d '{"model":"kr/claude-haiku-4.5","messages":[{"role":"user","content":"ping"}],"max_tokens":64,"stream":false}'
