{
  "name": "@infinity-canvas/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Infinity Canvas Electron Desktop App",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
