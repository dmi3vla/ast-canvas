{
  "name": "@infinity-canvas/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Infinity Canvas Electron Desktop App",
  "author": "Infinity Canvas",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "clean": "rm -rf out/ dist/",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "build": {
    "appId": "dev.infinity-canvas.app",
    "productName": "Infinity Canvas",
    "executableName": "infinity-canvas",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "executableName": "infinity-canvas"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis"]
    }
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@infinity-canvas/ast-graph": "workspace:*",
    "@infinity-canvas/canvas-core": "workspace:*",
    "@infinity-canvas/detail-pane": "workspace:*",
    "@infinity-canvas/ipc": "workspace:*",
    "@infinity-canvas/schema": "workspace:*",
    "@infinity-canvas/semantic": "workspace:*",
    "@infinity-canvas/session": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
